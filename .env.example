# Environment Configuration for Conductor Agent
# Copy this file to .env and fill in your API keys

# ==============================================
# LLM API Keys (Choose at least one)
# ==============================================

# OpenAI API Key (GPT-4, GPT-3.5-turbo, text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI API Key (Gemini models)
# GOOGLE_API_KEY=your_google_api_key_here

# ----------------------------------------------
# AWS Bedrock (Claude, Titan, Llama, etc. via AWS)
# ----------------------------------------------
# Two ways to authenticate — pick ONE:
#
# 1) Bedrock API key (simplest). Create one in the AWS console:
#    Amazon Bedrock -> "API keys" -> Generate. Then set:
# AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here
#
# 2) Standard AWS access-key credentials (an IAM user/role with the
#    "bedrock:InvokeModel" permission). Get them from the AWS console:
#    IAM -> Users -> Security credentials -> Create access key.
# AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# AWS_SESSION_TOKEN=            # only for temporary/STS credentials
#
# Region must be one where Bedrock + your chosen model are enabled, and
# you must request model access in the Bedrock console first.
AWS_REGION=us-east-1
# Model to call (on-demand or an inference-profile id, e.g.
# us.anthropic.claude-3-5-sonnet-20241022-v2:0)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ==============================================
# Model Configuration
# ==============================================

# Primary LLM for conductor agent
CONDUCTOR_MODEL=gpt-4o-mini
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet, gemini-pro

# Embedding model for vector store
EMBEDDING_MODEL=text-embedding-3-small
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002

# ==============================================
# Vector Database Configuration
# ==============================================

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# Collection names
CONVERSATIONS_COLLECTION=conversations
CODE_COLLECTION=code_snippets
DECISIONS_COLLECTION=decisions
SOLUTIONS_COLLECTION=solutions

# ==============================================
# Data Processing Configuration
# ==============================================

# Chunk size for text splitting (tokens)
CHUNK_SIZE=1000

# Chunk overlap for context preservation
CHUNK_OVERLAP=200

# Maximum chunks to retrieve per query
TOP_K=5

# ==============================================
# API Server Configuration
# ==============================================

# Server host and port (Cloud Run / Render override PORT at runtime)
API_HOST=0.0.0.0
API_PORT=8080

# Enable debug mode
DEBUG=False

# ==============================================
# Data Paths
# ==============================================

# Path to raw exported data
RAW_DATA_DIR=./data/raw

# Path to processed data
PROCESSED_DATA_DIR=./data/processed

# Path to Antigravity conversation logs (leave blank if unused;
# on Windows e.g. C:/Users/<you>/.gemini/antigravity/brain)
ANTIGRAVITY_BRAIN_DIR=

# ==============================================
# Logging Configuration
# ==============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/conductor.log
