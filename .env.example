# Environment Configuration for Conductor Agent
# Copy this file to .env and fill in your API keys.
# On Cloud Run, inject secrets via Google Cloud Secret Manager instead.

# ==============================================
# LLM API Keys (OPENAI_API_KEY is required)
# ==============================================

# OpenAI API Key (GPT-4, GPT-3.5-turbo, text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Claude models) – optional
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI API Key (Gemini models) – optional
# GOOGLE_API_KEY=your_google_api_key_here

# ==============================================
# Model Configuration
# ==============================================

# Primary LLM for conductor agent
CONDUCTOR_MODEL=gpt-4o-mini
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet, gemini-pro

# Embedding model for vector store
EMBEDDING_MODEL=text-embedding-3-small
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002

# ==============================================
# Vector Database Configuration
# ==============================================

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# Collection names
CONVERSATIONS_COLLECTION=conversations
CODE_COLLECTION=code_snippets
DECISIONS_COLLECTION=decisions
SOLUTIONS_COLLECTION=solutions

# ==============================================
# Data Processing Configuration
# ==============================================

# Chunk size for text splitting (tokens)
CHUNK_SIZE=1000

# Chunk overlap for context preservation
CHUNK_OVERLAP=200

# Maximum chunks to retrieve per query
TOP_K=5

# ==============================================
# API Server Configuration
# ==============================================

# Server host (always 0.0.0.0 for container deployments)
API_HOST=0.0.0.0

# Server port – Cloud Run injects PORT at runtime (overrides this value).
# Set to 8080 here for local Docker development.
PORT=8080

# Enable debug mode
DEBUG=False

# ==============================================
# Data Paths
# ==============================================

# Path to raw exported data
RAW_DATA_DIR=./data/raw

# Path to processed data
PROCESSED_DATA_DIR=./data/processed

# Path to conversation logs (optional, local use only)
# ANTIGRAVITY_BRAIN_DIR=./data/brain

# ==============================================
# Logging Configuration
# ==============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/conductor.log

