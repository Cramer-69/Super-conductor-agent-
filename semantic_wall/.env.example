# Semantic Wall — environment configuration.
# Copy to semantic_wall/.env and fill in. This service is independent of
# the sibling app's .env — separate deployment, separate credentials.

# ==============================================
# Supabase (memory datastore) — required for persistent memory
# ==============================================
# Create a project at https://supabase.com, run semantic_wall/db/schema.sql
# in its SQL editor, then fill these in. Without them, the service still
# runs — /api/chat just answers without memory and /api/checkin no-ops on
# persistence — see README.md.
SUPABASE_URL=
SUPABASE_KEY=

# ==============================================
# LLM providers — at least one needed for the agent to answer at all
# ==============================================
# The blueprint's Phase 1 choice is Claude or Grok; OpenAI is also wired
# and fine to use.
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# Which provider the agent prefers when more than one key is set.
DEFAULT_AGENT_MODEL_PROVIDER=anthropic

# ==============================================
# Check-in engine
# ==============================================
CHECKIN_INTERVAL_MINUTES=30

# ==============================================
# API server
# ==============================================
API_HOST=0.0.0.0
API_PORT=8090
